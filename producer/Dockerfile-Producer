FROM python:3.11.13-bookworm

ENV PYTHONUNBUFFERED=1

RUN pip install --no-cache-dir python-dotenv==1.1.1 confluent-kafka[avro]==2.11.0

WORKDIR /home/app

# Bake application source into the image for immutable, reproducible containers.
# No volume mounts needed at runtime.
COPY config.py custom_types.py producer.py schema_registry.py user_event_schema.avsc ./

CMD ["python", "producer.py"]
