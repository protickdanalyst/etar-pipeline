AIRFLOW__CORE__FERNET_KEY=REPLACE_WITH_GENERATED_FERNET_KEY

# API secret key: any long random string
AIRFLOW__API__SECRET_KEY=REPLACE_WITH_RANDOM_SECRET_KEY

# Airflow web UI admin credentials
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
